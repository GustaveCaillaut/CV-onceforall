{
  "command": "train_supernet",
  "seed": 0,
  "device": "cuda",
  "save_dir": "./runs/ofa_cifar10",
  "data_dir": "./data",
  "batch_size": 128,
  "num_workers": 4,
  "val_split": 5000,
  "lr": 0.05,
  "shrink_lr": 0.005,
  "weight_decay": 0.0003,
  "epochs_largest": 5,
  "epochs_kernel": 2,
  "epochs_depth1": 1,
  "epochs_depth2": 2,
  "epochs_width1": 1,
  "epochs_width2": 2,
  "kd_ratio": 0.5,
  "kd_temperature": 2.0,
  "channel_sort": true,
  "save_every": 10,
  "log_interval": 50
}